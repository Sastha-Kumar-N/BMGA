NODE_ENV=production
BACKEND_NODE_ENV=production
ALLOW_INSECURE_DEV_SECRETS=false

APP_NAME=bmga
APP_VERSION=
PORT=8080
BACKEND_PORT=3001

POSTGRES_DB=bmga
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000

JWT_SECRET=
NEXTAUTH_SECRET=
AUTH_SECRET=
SESSION_MAX_AGE_SECONDS=28800
SESSION_UPDATE_AGE_SECONDS=900

CORS_ORIGIN=
FRONTEND_URL=
NEXTAUTH_URL=
BACKEND_INTERNAL_URL=
TRUST_PROXY=1

RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_MAX=10
ADMIN_RATE_LIMIT_MAX=300
IMPORT_RATE_LIMIT_MAX=40

REQUEST_BODY_LIMIT=1mb
MAX_IMPORT_FILE_BYTES=5242880
UPLOAD_ROOT=/app/uploads
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=
S3_PREFIX=bmga
S3_KMS_KEY_ID=

ADMIN_ALLOWED_IPS=
ADMIN_EMAIL_DOMAINS=

LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

BMGA_ADMIN_EMAIL=
BMGA_ADMIN_PASSWORD=
BMGA_DEMO_PASSWORD=
SEED_DEMO_USER=false
SEED_DEMO_DATA=false
