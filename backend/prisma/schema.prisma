generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STUDENT
  RESEARCHER
  INDUSTRY
  OTHER
  CONTRIBUTOR
  MODERATOR
}

enum UserAffiliation {
  INDUSTRY
  ACADEMIC
  RESEARCH
}

enum ApprovalStatus {
  PENDING
  UNDER_REVIEW
  NEEDS_CHANGES
  APPROVED
  REJECTED
  ARCHIVED
}

enum ContactMessageStatus {
  UNREAD
  READ
}

enum ToolRunStatus {
  COMPLETED
  FAILED
  PENDING
  NOT_AVAILABLE
  WARNING
  PARTIAL
}

enum EvidenceBasis {
  GENOTYPIC
  PHENOTYPIC
  COMBINED
  NOT_REPORTED
}

enum SurveillanceScope {
  NATIONAL
  GLOBAL
}

enum SubmissionFileStatus {
  UPLOADED
  PROCESSING
  INGESTED
  FAILED
}

enum GenomeReferenceKind {
  FASTA
  FAI
  GFF3
}

enum GenomeReferenceStatus {
  UPLOADED
  PUBLISHED
  FAILED
  ARCHIVED
}

model User {
  id                      String                    @id @default(uuid())
  email                   String                    @unique
  passwordHash            String                    @map("password")
  name                    String
  affiliation             UserAffiliation           @default(RESEARCH)
  role                    UserRole                  @default(STUDENT)
  authVersion             Int                       @default(0)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  profile                 UserProfile?
  organismUploads         OrganismUpload[]          @relation("UserOrganismUploads")
  reviewedOrganismUploads OrganismUpload[]          @relation("ReviewedOrganismUploads")
  submissionStatusHistory SubmissionStatusHistory[] @relation("SubmissionStatusActors")
  submissionReviewerNotes SubmissionReviewerNote[]  @relation("SubmissionReviewerNoteAuthors")
  blogPosts               BlogPost[]                @relation("UserBlogPosts")
  reviewedBlogPosts       BlogPost[]                @relation("ReviewedBlogPosts")
  adminLogs               AdminLog[]                @relation("AdminLogs")
}

model UserProfile {
  id                         String   @id @default(uuid())
  userId                     String   @unique
  title                      String?
  gender                     String?
  dateOfBirth                DateTime?
  phone                      String?
  institutionalAddress       String?
  country                    String?
  city                       String?
  designation                String?
  department                 String?
  institution                String?
  employmentStatus           String?
  highestDegree              String?
  specialization             String?
  researchInterests          String?
  researchAreas              String?
  keywords                   String?
  currentProjects            String?
  orcidId                    String?
  researcherId               String?
  scopusAuthorId             String?
  googleScholarUrl           String?
  linkedInUrl                String?
  profilePhotoPath           String?
  profilePhotoName           String?
  profilePhotoContentType    String?
  profilePhotoSizeBytes      Int?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([country])
  @@index([institution])
  @@index([orcidId])
}

model Organism {
  id             Int       @id @default(autoincrement())
  scientificName String    @unique
  displayName    String?
  taxonomyId     Int?
  domain         String?
  phylum         String?
  className      String?
  orderName      String?
  family         String?
  genus          String?
  species        String?
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  strains        Strain[]
  toolRuns       ToolRun[]

  @@index([genus])
  @@index([species])
}

model Strain {
  id                    Int               @id @default(autoincrement())
  organismId            Int
  strainName            String
  isolateName           String?
  strainCode            String?
  biosampleAccession    String?
  bioprojectAccession   String?
  assemblyAccession     String?
  sourceType            String?
  host                  String?
  country               String?
  state                 String?
  city                  String?
  collectionDate        DateTime?
  locationText          String?
  latitude              Float?
  longitude             Float?
  genomeStatus          String?
  genomeSize            Int?
  gcContent             Decimal?          @db.Decimal(5, 2)
  repoLink              String?
  metadata              Json?
  surveillanceScope     SurveillanceScope @default(GLOBAL)
  evidenceBasis         EvidenceBasis     @default(GENOTYPIC)
  submittingInstitution String?
  dataSource            String?
  dataUseLimitations    String?
  lastVerifiedAt        DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  organism         Organism              @relation(fields: [organismId], references: [id], onDelete: Cascade)
  assemblies       Assembly[]
  qcReports        QcReport[]
  annotationRuns   AnnotationRun[]
  genomicFeatures  GenomicFeature[]
  fileAssets       FileAsset[]
  amrGenes         AmrGene[]
  analysisRuns     AnalysisRun[]
  toolRuns         ToolRun[]
  genomeReferences GenomeReferenceFile[]

  @@index([organismId])
  @@index([strainName])
  @@index([assemblyAccession])
  @@index([country])
  @@index([country, collectionDate])
  @@index([organismId, collectionDate])
  @@index([sourceType])
  @@index([surveillanceScope, updatedAt])
  @@index([evidenceBasis])
  @@index([state])
  @@index([city])
}

model OrganismUpload {
  id                    String            @id @default(uuid())
  submittedById         String
  reviewedById          String?
  status                ApprovalStatus    @default(PENDING)
  reviewNote            String?
  scientificName        String
  displayName           String?
  taxonomyId            Int?
  domain                String?
  phylum                String?
  className             String?
  orderName             String?
  family                String?
  genus                 String?
  species               String?
  description           String?
  strainName            String
  isolateName           String?
  strainCode            String?
  biosampleAccession    String?
  bioprojectAccession   String?
  assemblyAccession     String?
  sourceType            String?
  host                  String?
  country               String?
  state                 String?
  city                  String?
  collectionDate        DateTime?
  locationText          String?
  latitude              Float?
  longitude             Float?
  genomeStatus          String?
  genomeSize            Int?
  gcContent             Decimal?          @db.Decimal(5, 2)
  repoLink              String?
  metadata              Json?
  surveillanceScope     SurveillanceScope @default(GLOBAL)
  evidenceBasis         EvidenceBasis     @default(GENOTYPIC)
  submittingInstitution String?
  dataSource            String?
  dataUseLimitations    String?
  lastVerifiedAt        DateTime?
  publishedOrganismId   Int?
  publishedStrainId     Int?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  reviewedAt            DateTime?

  submittedBy      User                      @relation("UserOrganismUploads", fields: [submittedById], references: [id], onDelete: Cascade)
  reviewedBy       User?                     @relation("ReviewedOrganismUploads", fields: [reviewedById], references: [id], onDelete: SetNull)
  statusHistory    SubmissionStatusHistory[]
  reviewerNotes    SubmissionReviewerNote[]
  files            SubmissionFile[]
  genomeReferences GenomeReferenceFile[]

  @@index([submittedById])
  @@index([reviewedById])
  @@index([status])
  @@index([surveillanceScope, status])
  @@index([country, createdAt])
  @@index([evidenceBasis])
  @@index([scientificName])
  @@index([strainName])
}

model SubmissionFile {
  id               String               @id @default(uuid())
  submissionId     String
  toolName         String
  originalFileName String
  fileType         String
  fileSizeBytes    Int
  checksumSha256   String
  storagePath      String
  toolVersion      String?
  summary          Json?
  warnings         Json?
  errors           Json?
  status           SubmissionFileStatus @default(UPLOADED)
  errorMessage     String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  ingestedAt       DateTime?

  submission OrganismUpload @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
  @@index([toolName, status])
  @@index([status])
}

model GenomeReferenceFile {
  id               String                @id @default(uuid())
  submissionId     String?
  strainId         Int?
  kind             GenomeReferenceKind
  originalFileName String
  contentType      String
  fileSizeBytes    Int
  checksumSha256   String
  storagePath      String
  status           GenomeReferenceStatus @default(UPLOADED)
  isPublic         Boolean               @default(false)
  validation       Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  publishedAt      DateTime?

  submission OrganismUpload? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  strain     Strain?         @relation(fields: [strainId], references: [id], onDelete: Cascade)

  @@unique([submissionId, kind])
  @@unique([strainId, kind])
  @@index([submissionId, createdAt])
  @@index([strainId, status])
  @@index([kind, status, isPublic])
  @@index([checksumSha256])
}

model SubmissionStatusHistory {
  id                 String   @id @default(uuid())
  submissionId       String
  status             String
  actorId            String?
  note               String?
  visibleToSubmitter Boolean  @default(true)
  createdAt          DateTime @default(now())

  submission OrganismUpload @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  actor      User?          @relation("SubmissionStatusActors", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([submissionId])
  @@index([actorId])
  @@index([status])
  @@index([createdAt])
}

model SubmissionReviewerNote {
  id                 String   @id @default(uuid())
  submissionId       String
  authorId           String?
  message            String
  visibleToSubmitter Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  submission OrganismUpload @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author     User?          @relation("SubmissionReviewerNoteAuthors", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([submissionId])
  @@index([authorId])
  @@index([visibleToSubmitter])
  @@index([createdAt])
}

model BlogPost {
  id           String         @id @default(uuid())
  title        String
  content      String
  authorId     String
  reviewedById String?
  status       ApprovalStatus @default(PENDING)
  reviewNote   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  reviewedAt   DateTime?

  author     User  @relation("UserBlogPosts", fields: [authorId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ReviewedBlogPosts", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([authorId])
  @@index([reviewedById])
  @@index([status])
  @@index([createdAt])
}

model AdminLog {
  id         String   @id @default(uuid())
  adminId    String?
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  admin User? @relation("AdminLogs", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([action])
  @@index([targetType])
  @@index([targetType, targetId, createdAt])
  @@index([createdAt])
}

model ContactMessage {
  id           String               @id @default(uuid())
  name         String
  email        String
  organization String?
  subject      String
  message      String
  status       ContactMessageStatus @default(UNREAD)
  adminNotes   String?
  archived     Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([status])
  @@index([archived])
  @@index([createdAt])
  @@index([email])
}

model Assembly {
  id              Int      @id @default(autoincrement())
  strainId        Int
  assemblyName    String?
  assemblyVersion String?
  assembler       String?
  assemblyLevel   String?
  contigCount     Int?
  scaffoldCount   Int?
  n50             Int?
  l50             Int?
  longestContig   Int?
  totalLength     Int?
  gapCount        Int?
  metadata        Json?
  createdAt       DateTime @default(now())

  strain     Strain      @relation(fields: [strainId], references: [id], onDelete: Cascade)
  fileAssets FileAsset[]

  @@index([strainId])
}

model QcReport {
  id                             Int      @id @default(autoincrement())
  strainId                       Int
  qcTool                         String
  reportType                     String?
  perBaseQualityStatus           String?
  perSequenceQualityStatus       String?
  adapterContentStatus           String?
  duplicationStatus              String?
  overrepresentedSequencesStatus String?
  percentGc                      Decimal? @db.Decimal(5, 2)
  totalSequences                 Int?
  summary                        Json?
  createdAt                      DateTime @default(now())

  strain Strain @relation(fields: [strainId], references: [id], onDelete: Cascade)

  @@index([strainId])
  @@index([qcTool])
}

model AnnotationRun {
  id              Int      @id @default(autoincrement())
  strainId        Int
  toolName        String
  toolVersion     String?
  cdsCount        Int?
  trnaCount       Int?
  rrnaCount       Int?
  ncrnaCount      Int?
  pseudogeneCount Int?
  metadata        Json?
  createdAt       DateTime @default(now())

  strain          Strain           @relation(fields: [strainId], references: [id], onDelete: Cascade)
  genomicFeatures GenomicFeature[]
  fileAssets      FileAsset[]

  @@index([strainId])
  @@index([toolName])
}

model GenomicFeature {
  id              Int      @id @default(autoincrement())
  strainId        Int
  annotationRunId Int?
  seqid           String?
  locusTag        String?
  geneName        String?
  featureType     String
  startPos        Int
  endPos          Int
  strand          String?
  product         String?
  proteinId       String?
  geneBiotype     String?
  attributes      Json?
  createdAt       DateTime @default(now())

  strain        Strain         @relation(fields: [strainId], references: [id], onDelete: Cascade)
  annotationRun AnnotationRun? @relation(fields: [annotationRunId], references: [id], onDelete: SetNull)

  @@index([strainId])
  @@index([geneName])
  @@index([locusTag])
  @@index([featureType])
}

model FileAsset {
  id              Int      @id @default(autoincrement())
  strainId        Int?
  assemblyId      Int?
  annotationRunId Int?
  analysisRunId   Int?
  fileType        String
  fileName        String
  bucketName      String
  objectKey       String
  contentType     String?
  fileSizeBytes   Int?
  checksumSha256  String?
  isPublic        Boolean  @default(false)
  metadata        Json?
  createdAt       DateTime @default(now())

  strain        Strain?        @relation(fields: [strainId], references: [id], onDelete: Cascade)
  assembly      Assembly?      @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  annotationRun AnnotationRun? @relation(fields: [annotationRunId], references: [id], onDelete: Cascade)
  analysisRun   AnalysisRun?   @relation("AnalysisRunOutputFiles", fields: [analysisRunId], references: [id], onDelete: Cascade)

  inputToRuns AnalysisRun[] @relation("AnalysisRunInputFile")
  toolResults ToolResult[]

  @@index([fileType])
}

model AnalysisRun {
  id         Int      @id @default(autoincrement())
  strainId   Int
  sampleName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  strain      Strain       @relation(fields: [strainId], references: [id], onDelete: Cascade)
  inputFileId Int?
  inputFile   FileAsset?   @relation("AnalysisRunInputFile", fields: [inputFileId], references: [id], onDelete: SetNull)
  outputFiles FileAsset[]  @relation("AnalysisRunOutputFiles")
  toolResults ToolResult[]

  fastqc     FastqcResult?
  fastp      FastpResult?
  multiqc    MultiqcResult?
  spades     SpadesResult?
  quast      QuastResult?
  busco      BuscoResult?
  checkm     CheckmResult?
  prokka     ProkkaResult?
  diamond    DiamondResult?
  kofamkoala KofamkoalaResult?
  abricate   AbricateResult?
  mlst       MlstResult?
  islandPath IslandPathResult?
  trnascan   TrnascanSeResult?
  hmmer      HmmerResult?
  minced     MincedResult?
  jellyfish  JellyfishResult?
  trf        TrfResult?
  barrnap    BarrnapResult?
  antismash  AntismashResult?

  @@index([strainId])
}

model FastqcResult {
  id                   Int     @id @default(autoincrement())
  analysisRunId        Int     @unique
  totalReads           Int?
  gcContent            Float?
  q30Rate              Float?
  duplicationRate      Float?
  sequenceLengthMinBp  Int?
  sequenceLengthMaxBp  Int?
  adapterContentStatus String?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model FastpResult {
  id                   Int    @id @default(autoincrement())
  analysisRunId        Int    @unique
  readsBeforeFiltering Int?
  readsAfterFiltering  Int?
  q20Rate              Float?
  q30Rate              Float?
  duplicationRate      Float?
  insertSizePeakBp     Int?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model MultiqcResult {
  id                  Int    @id @default(autoincrement())
  analysisRunId       Int    @unique
  samplesAnalysed     Int?
  avgSequenceLengthBp Int?
  gcContent           Float?
  duplicatesR1        Float?
  duplicatesR2        Float?
  failedModules       Int?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model SpadesResult {
  id              Int    @id @default(autoincrement())
  analysisRunId   Int    @unique
  totalContigs    Int?
  largestContigKb Float?
  n50Kb           Float?
  totalLengthMb   Float?
  coverageX       Float?
  peakMemoryGb    Float?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model QuastResult {
  id                 Int    @id @default(autoincrement())
  analysisRunId      Int    @unique
  n50Kb              Float?
  l50                Int?
  genomeFraction     Float?
  mismatchesPer100Kb Float?
  largestContigKb    Float?
  duplicationRatio   Float?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model BuscoResult {
  id                Int     @id @default(autoincrement())
  analysisRunId     Int     @unique
  completePercent   Float?
  singleCopyPercent Float?
  duplicatedPercent Float?
  fragmentedPercent Float?
  missingPercent    Float?
  lineage           String?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model CheckmResult {
  id                  Int     @id @default(autoincrement())
  analysisRunId       Int     @unique
  completeness        Float?
  contamination       Float?
  strainHeterogeneity Float?
  qualityScore        Float?
  markerGenes         Int?
  lineage             String?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model ProkkaResult {
  id                   Int    @id @default(autoincrement())
  analysisRunId        Int    @unique
  cdsCount             Int?
  rrnaGenes            Int?
  trnaGenes            Int?
  hypotheticalProteins Int?
  codingDensity        Float?
  pseudogenes          Int?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model DiamondResult {
  id               Int     @id @default(autoincrement())
  analysisRunId    Int     @unique
  queriesAligned   Int?
  percentAligned   Float?
  databaseName     String?
  avgIdentity      Float?
  evalueCutoff     String?
  unalignedQueries Int?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model KofamkoalaResult {
  id             Int     @id @default(autoincrement())
  analysisRunId  Int     @unique
  genesAnnotated Int?
  keggPathways   Int?
  koCoverage     Float?
  avgHmmScore    Float?
  dbRelease      String?
  topPathway     String?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model AbricateResult {
  id             Int     @id @default(autoincrement())
  analysisRunId  Int     @unique
  genesFound     Int?
  minCoverage    Float?
  minIdentity    Float?
  topHit         String?
  virulenceGenes Int?
  plasmidGenes   Int?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model MlstResult {
  id              Int      @id @default(autoincrement())
  analysisRunId   Int      @unique
  scheme          String?
  sequenceType    String?
  allelesMatched  String?
  confidence      Float?
  clonalComplex   String?
  pandemicLineage Boolean?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model IslandPathResult {
  id              Int      @id @default(autoincrement())
  analysisRunId   Int      @unique
  gisDetected     Int?
  totalGiLengthKb Float?
  avgGiLengthKb   Float?
  giLinkedGenes   Int?
  amrIsland       Boolean?
  amrIslandName   String?
  amrGene         String?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model TrnascanSeResult {
  id             Int     @id @default(autoincrement())
  analysisRunId  Int     @unique
  trnasFound     Int?
  aminoAcidTypes Int?
  pseudoTrnas    Int?
  anticodons     Int?
  hotspots       Int?
  modelType      String?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model HmmerResult {
  id            Int     @id @default(autoincrement())
  analysisRunId Int     @unique
  domainsFound  Int?
  pfamHits      Int?
  tigrfamHits   Int?
  avgEvalue     String?
  databases     String?
  novelDomains  Int?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model MincedResult {
  id              Int     @id @default(autoincrement())
  analysisRunId   Int     @unique
  crisprArrays    Int?
  totalSpacers    Int?
  repeatLengthBp  Int?
  spacerLengthBp  Int?
  phageMatches    Int?
  arraysOnContigs String?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model JellyfishResult {
  id                   Int    @id @default(autoincrement())
  analysisRunId        Int    @unique
  kmerSize             Int?
  distinctKmersMillion Float?
  totalKmersBillion    Float?
  peakFrequencyX       Float?
  genomeSizeMb         Float?
  repeatContent        Float?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model TrfResult {
  id                 Int    @id @default(autoincrement())
  analysisRunId      Int    @unique
  tandemRepeats      Int?
  totalLengthKb      Float?
  genomeFraction     Float?
  avgPeriodSizeBp    Int?
  maxCopy            Float?
  phaseVariationLoci Int?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model BarrnapResult {
  id            Int     @id @default(autoincrement())
  analysisRunId Int     @unique
  rrna16S       Int?
  rrna23S       Int?
  rrna5S        Int?
  totalRrna     Int?
  evalueCutoff  String?
  taxonomy      String?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model AntismashResult {
  id            Int     @id @default(autoincrement())
  analysisRunId Int     @unique
  bgcRegions    Int?
  bgcTypes      String?
  mibigMatches  Int?
  novelBgcs     Int?
  mibigHit      String?
  databaseName  String?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model AmrGene {
  id                  Int           @id @default(autoincrement())
  strainId            Int
  toolRunId           Int?
  geneSymbol          String
  drugClass           String?
  drugName            String?
  resistanceMechanism String?
  identity            Float?
  coverage            Float?
  databaseName        String?
  phenotype           String?
  evidenceBasis       EvidenceBasis @default(GENOTYPIC)
  createdAt           DateTime      @default(now())

  strain  Strain   @relation(fields: [strainId], references: [id], onDelete: Cascade)
  toolRun ToolRun? @relation(fields: [toolRunId], references: [id], onDelete: SetNull)

  @@index([strainId])
  @@index([toolRunId])
  @@index([geneSymbol])
  @@index([drugClass])
  @@index([evidenceBasis])
  @@index([createdAt])
}

model ToolResult {
  id            Int      @id @default(autoincrement())
  analysisRunId Int
  resultType    String
  title         String?
  description   String?
  format        String?
  fileAssetId   Int?
  jsonData      Json?
  textData      String?
  createdAt     DateTime @default(now())

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  fileAsset   FileAsset?  @relation(fields: [fileAssetId], references: [id], onDelete: SetNull)

  @@index([analysisRunId])
  @@index([resultType])
}

model ToolRun {
  id         Int           @id @default(autoincrement())
  organismId Int
  strainId   Int?
  toolName   String
  status     ToolRunStatus @default(PENDING)
  version    String?
  startedAt  DateTime?
  finishedAt DateTime?
  summary    Json?
  warnings   Json?
  errors     Json?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  organism Organism          @relation(fields: [organismId], references: [id], onDelete: Cascade)
  strain   Strain?           @relation(fields: [strainId], references: [id], onDelete: Cascade)
  tables   ToolResultTable[]
  files    ToolOutputFile[]
  amrGenes AmrGene[]

  @@index([organismId])
  @@index([strainId])
  @@index([toolName])
  @@index([status])
}

model ToolResultTable {
  id        Int      @id @default(autoincrement())
  toolRunId Int
  tableName String
  columns   Json
  rows      Json
  createdAt DateTime @default(now())

  toolRun ToolRun @relation(fields: [toolRunId], references: [id], onDelete: Cascade)

  @@index([toolRunId])
}

model ToolOutputFile {
  id          Int      @id @default(autoincrement())
  toolRunId   Int
  fileName    String
  fileType    String?
  filePath    String
  description String?
  createdAt   DateTime @default(now())

  toolRun ToolRun @relation(fields: [toolRunId], references: [id], onDelete: Cascade)

  @@index([toolRunId])
  @@index([fileType])
}
