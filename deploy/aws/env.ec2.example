# This is the lowest-cost production topology: PostgreSQL runs privately in Docker
# on the same EC2 instance. Do not use special characters in POSTGRES_PASSWORD;
# use the documented hex generator so the application connection string remains valid.
BMGA_DOMAIN=bmga.example.org
ACME_EMAIL=admin@example.org
APP_NAME=bmga
APP_VERSION=

NEXTAUTH_URL=https://bmga.example.org
PUBLIC_BASE_URL=https://bmga.example.org
FRONTEND_URL=https://bmga.example.org
CORS_ORIGIN=https://bmga.example.org

POSTGRES_DB=bmga
POSTGRES_USER=bmga_app
POSTGRES_PASSWORD=REPLACE_WITH_64_HEX_CHARACTERS

JWT_SECRET=REPLACE_WITH_64_PLUS_RANDOM_CHARACTERS
NEXTAUTH_SECRET=REPLACE_WITH_64_PLUS_RANDOM_CHARACTERS

BMGA_ADMIN_EMAIL=admin@example.org
BMGA_ADMIN_PASSWORD=REPLACE_WITH_A_LONG_UNIQUE_ADMIN_PASSWORD

S3_BUCKET=your-private-bmga-data-bucket
S3_REGION=ap-south-1
S3_PREFIX=bmga-prod
S3_KMS_KEY_ID=

LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_MAX=10
ACCOUNT_SECURITY_RATE_LIMIT_MAX=10
ADMIN_RATE_LIMIT_MAX=300
IMPORT_RATE_LIMIT_MAX=40
SURVEILLANCE_RATE_LIMIT_MAX=600
REQUEST_BODY_LIMIT=6mb
GENOME_REFERENCE_BODY_LIMIT=32mb
MAX_IMPORT_FILE_BYTES=5242880
MAX_GENOME_REFERENCE_BYTES=26214400
MAX_PROFILE_PHOTO_BYTES=2097152
BLAST_RATE_LIMIT_MAX=20
MAX_BLAST_QUERY_BASES=50000
BLAST_TIMEOUT_MS=30000
BLAST_MAX_CONCURRENT=2

DATASET_CONTACT_EMAIL=admin@example.org
DATASET_LICENSE_NAME=
DATASET_LICENSE_URL=
FAIRSHARING_RECORD_URL=
DATASET_DOI=

# Optional hardening. Leave blank until you know the fixed source IP ranges.
ADMIN_ALLOWED_IPS=
ADMIN_EMAIL_DOMAINS=
